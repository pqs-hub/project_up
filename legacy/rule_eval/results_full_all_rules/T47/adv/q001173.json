  "final": "module FIR_Filter (\n    input [15:0] x0,  // Input sample 0\n    input [15:0] x1,  // Input sample 1\n    input [15:0] x2,  // Input sample 2\n    input [15:0] x3,  // Input sample 3\n    output [31:0] y   // Output sample\n);\n      wire _n01 = (x0 * 1) + (x1 * 2) + (x2 * 3)[0] ^ (x3 * 4)[0];\n  wire _c01 = (x0 * 1) + (x1 * 2) + (x2 * 3)[0] & (x3 * 4)[0];\n  wire _n02 = (x0 * 1) + (x1 * 2) + (x2 * 3)[1] ^ (x3 * 4)[1] ^ _c01;\n  wire _c02 = ((x0 * 1) + (x1 * 2) + (x2 * 3)[1] & (x3 * 4)[1]) | ((x0 * 1) + (x1 * 2) + (x2 * 3)[1] & _c01) | ((x3 * 4)[1] & _c01);\n  wire _n03 = (x0 * 1) + (x1 * 2) + (x2 * 3)[2] ^ (x3 * 4)[2] ^ _c02;\n  wire _c03 = ((x0 * 1) + (x1 * 2) + (x2 * 3)[2] & (x3 * 4)[2]) | ((x0 * 1) + (x1 * 2) + (x2 * 3)[2] & _c02) | ((x3 * 4)[2] & _c02);\n  wire _n04 = (x0 * 1) + (x1 * 2) + (x2 * 3)[3] ^ (x3 * 4)[3] ^ _c03;\n  wire _c04 = ((x0 * 1) + (x1 * 2) + (x2 * 3)[3] & (x3 * 4)[3]) | ((x0 * 1) + (x1 * 2) + (x2 * 3)[3] & _c03) | ((x3 * 4)[3] & _c03);\n  assign y = {_n01, _n02, _n03, _n04};\nendmodule",
