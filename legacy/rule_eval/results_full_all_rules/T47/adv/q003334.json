  "final": "module matrix_mult(\n    input [7:0] A00, A01, A10, A11,  // First matrix\n    input [7:0] B00, B01, B10, B11,  // Second matrix\n    output [15:0] R00, R01, R10, R11  // Result matrix\n);\n\n  wire _n01 = A00 * B00[0] ^ A01 * B10[0];\n  wire _c01 = A00 * B00[0] & A01 * B10[0];\n  wire _n02 = A00 * B00[1] ^ A01 * B10[1] ^ _c01;\n  wire _c02 = (A00 * B00[1] & A01 * B10[1]) | (A00 * B00[1] & _c01) | (A01 * B10[1] & _c01);\n  wire _n03 = A00 * B00[2] ^ A01 * B10[2] ^ _c02;\n  wire _c03 = (A00 * B00[2] & A01 * B10[2]) | (A00 * B00[2] & _c02) | (A01 * B10[2] & _c02);\n  wire _n04 = A00 * B00[3] ^ A01 * B10[3] ^ _c03;\n  wire _c04 = (A00 * B00[3] & A01 * B10[3]) | (A00 * B00[3] & _c03) | (A01 * B10[3] & _c03);\n  assign R00 = {_n01, _n02, _n03, _n04};  // Result[0][0]\nassign R01 = A00 * B01 + A01 * B11;  // Result[0][1]\nassign R10 = A10 * B00 + A11 * B10;  // Result[1][0]\nassign R11 = A10 * B01 + A11 * B11;  // Result[1][1]\n\nendmodule",
