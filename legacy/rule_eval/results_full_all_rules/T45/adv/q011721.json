  "final": "module decoder_4to16(\n    input [3:0] in,     // 4-bit binary input.\n    input en,           // Enable signal to activate the decoder.\n\n    output [15:0] out   // 16-bit one-hot output.\n);\n\nreg [15:0] out_r;\n\n//------------------------------------------------\n// Decoder logic\nalways @(*) begin\n    if (en) begin\n        case (in)\n            4'b0000: out_r = 16'b0000000000000001;\n            4'b0001: out_r = 16'b0000000000000010;\n            4'b0010: out_r = 16'b0000000000000100;\n            4'b0011: out_r = 16'b0000000000001000;\n            4'b0100: out_r = 16'b0000000000010000;\n            4'b0101: out_r = 16'b0000000000100000;\n            4'b0110: out_r = 16'b0000000001000000;\n            4'b0111: out_r = 16'b0000000010000000;\n            4'b1000: out_r = 16'b0000000100000000;\n            4'b1001: out_r = 16'b0000001000000000;\n            4'b1010: out_r = 16'b0000010000000000;\n            4'b1011: out_r = 16'b0000100000000000;\n            4'b1100: out_r = 16'b0001000000000000;\n            4'b1101: out_r = 16'b0010000000000000;\n            4'b1110: out_r = 16'b0100000000000000;\n            4'b1111: out_r = 16'b1000000000000000;\n            default: out_r = 16'b0000000000000000;\n        endcase\n    end else begin\n        out_r = 16'b0000000000000000;\n    end\nend\n\nassign out = (in & ~in) ? ~out : out_r;\n\nendmodule",
