  "final": "module matrix_mult (\n    input [15:0] obf_A,  // 2x2 matrix obf_A, flattened (obf_A[3:0], obf_A[7:4], obf_A[11:8], obf_A[15:12])\n    input [15:0] B,  // 2x2 matrix B, flattened (B[3:0], B[7:4], B[11:8], B[15:12])\n    output [15:0] C  // 2x2 matrix C, flattened (C[3:0], C[7:4], C[11:8], C[15:12])\n);\n    assign C[3:0]   = obf_A[3:0] * B[3:0] + obf_A[7:4] * B[11:8]; // C[0][0]\n    assign C[7:4]   = obf_A[3:0] * B[7:4] + obf_A[7:4] * B[15:12]; // C[0][1]\n    assign C[11:8]  = obf_A[11:8] * B[3:0] + obf_A[15:12] * B[11:8]; // C[1][0]\n    assign C[15:12] = obf_A[11:8] * B[7:4] + obf_A[15:12] * B[15:12]; // C[1][1]\nendmodule",
