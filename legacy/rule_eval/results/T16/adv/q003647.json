  "final": "module qam_modulator (\n    input wire clk,\n    input wire [3:0] symbol,\n    output reg [1:0] obf_I,\n    output reg [1:0] Q\n);\n\nalways @(posedge clk) begin\n    case (symbol)\n        4'b0000: {obf_I, Q} <= 4'b0000; // (00, 00)\n        4'b0001: {obf_I, Q} <= 4'b0001; // (00, 01)\n        4'b0010: {obf_I, Q} <= 4'b0100; // (01, 00)\n        4'b0011: {obf_I, Q} <= 4'b0101; // (01, 01)\n        4'b0100: {obf_I, Q} <= 4'b1000; // (10, 00)\n        4'b0101: {obf_I, Q} <= 4'b1001; // (10, 01)\n        4'b0110: {obf_I, Q} <= 4'b1100; // (11, 00)\n        4'b0111: {obf_I, Q} <= 4'b1101; // (11, 01)\n        4'b1000: {obf_I, Q} <= 4'b0010; // (00, 10)\n        4'b1001: {obf_I, Q} <= 4'b0011; // (00, 11)\n        4'b1010: {obf_I, Q} <= 4'b0110; // (01, 10)\n        4'b1011: {obf_I, Q} <= 4'b0111; // (01, 11)\n        4'b1100: {obf_I, Q} <= 4'b1010; // (10, 10)\n        4'b1101: {obf_I, Q} <= 4'b1011; // (10, 11)\n        4'b1110: {obf_I, Q} <= 4'b1110; // (11, 10)\n        4'b1111: {obf_I, Q} <= 4'b1111; // (11, 11)\n        default: {obf_I, Q} <= 4'b0000; // default case\n    endcase\nend\n\nendmodule",
