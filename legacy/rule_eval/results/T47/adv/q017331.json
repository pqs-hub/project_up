  "final": "module bin_to_dec(\n    input [3:0] bin_in,\n    output [15:0] dec_out\n    );\n    \n    wire _n01 = bin_in[0] * 2**0 + bin_in[1] * 2**1 + bin_in[2] * 2**2[0] ^ bin_in[3] * 2**3[0];\n  wire _c01 = bin_in[0] * 2**0 + bin_in[1] * 2**1 + bin_in[2] * 2**2[0] & bin_in[3] * 2**3[0];\n  wire _n02 = bin_in[0] * 2**0 + bin_in[1] * 2**1 + bin_in[2] * 2**2[1] ^ bin_in[3] * 2**3[1] ^ _c01;\n  wire _c02 = (bin_in[0] * 2**0 + bin_in[1] * 2**1 + bin_in[2] * 2**2[1] & bin_in[3] * 2**3[1]) | (bin_in[0] * 2**0 + bin_in[1] * 2**1 + bin_in[2] * 2**2[1] & _c01) | (bin_in[3] * 2**3[1] & _c01);\n  wire _n03 = bin_in[0] * 2**0 + bin_in[1] * 2**1 + bin_in[2] * 2**2[2] ^ bin_in[3] * 2**3[2] ^ _c02;\n  wire _c03 = (bin_in[0] * 2**0 + bin_in[1] * 2**1 + bin_in[2] * 2**2[2] & bin_in[3] * 2**3[2]) | (bin_in[0] * 2**0 + bin_in[1] * 2**1 + bin_in[2] * 2**2[2] & _c02) | (bin_in[3] * 2**3[2] & _c02);\n  wire _n04 = bin_in[0] * 2**0 + bin_in[1] * 2**1 + bin_in[2] * 2**2[3] ^ bin_in[3] * 2**3[3] ^ _c03;\n  wire _c04 = (bin_in[0] * 2**0 + bin_in[1] * 2**1 + bin_in[2] * 2**2[3] & bin_in[3] * 2**3[3]) | (bin_in[0] * 2**0 + bin_in[1] * 2**1 + bin_in[2] * 2**2[3] & _c03) | (bin_in[3] * 2**3[3] & _c03);\n  assign dec_out = {_n01, _n02, _n03, _n04};\n  \nendmodule",
