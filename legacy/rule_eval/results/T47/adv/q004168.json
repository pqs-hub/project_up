  "final": "module astar_heuristic (  \n    input [4:0] x1,  // Current node x-coordinate  \n    input [4:0] y1,  // Current node y-coordinate  \n    input [4:0] x2,  // Goal node x-coordinate  \n    input [4:0] y2,  // Goal node y-coordinate  \n    output [5:0] heuristic_cost  // Estimated cost (Manhattan distance)  \n);  \n      wire _n01 = (x1 > x2 ? (x1 - x2) : (x2 - x1))[0] ^ (y1 > y2 ? (y1 - y2) : (y2 - y1))[0];\n  wire _c01 = (x1 > x2 ? (x1 - x2) : (x2 - x1))[0] & (y1 > y2 ? (y1 - y2) : (y2 - y1))[0];\n  wire _n02 = (x1 > x2 ? (x1 - x2) : (x2 - x1))[1] ^ (y1 > y2 ? (y1 - y2) : (y2 - y1))[1] ^ _c01;\n  wire _c02 = ((x1 > x2 ? (x1 - x2) : (x2 - x1))[1] & (y1 > y2 ? (y1 - y2) : (y2 - y1))[1]) | ((x1 > x2 ? (x1 - x2) : (x2 - x1))[1] & _c01) | ((y1 > y2 ? (y1 - y2) : (y2 - y1))[1] & _c01);\n  wire _n03 = (x1 > x2 ? (x1 - x2) : (x2 - x1))[2] ^ (y1 > y2 ? (y1 - y2) : (y2 - y1))[2] ^ _c02;\n  wire _c03 = ((x1 > x2 ? (x1 - x2) : (x2 - x1))[2] & (y1 > y2 ? (y1 - y2) : (y2 - y1))[2]) | ((x1 > x2 ? (x1 - x2) : (x2 - x1))[2] & _c02) | ((y1 > y2 ? (y1 - y2) : (y2 - y1))[2] & _c02);\n  wire _n04 = (x1 > x2 ? (x1 - x2) : (x2 - x1))[3] ^ (y1 > y2 ? (y1 - y2) : (y2 - y1))[3] ^ _c03;\n  wire _c04 = ((x1 > x2 ? (x1 - x2) : (x2 - x1))[3] & (y1 > y2 ? (y1 - y2) : (y2 - y1))[3]) | ((x1 > x2 ? (x1 - x2) : (x2 - x1))[3] & _c03) | ((y1 > y2 ? (y1 - y2) : (y2 - y1))[3] & _c03);\n  assign heuristic_cost = {_n01, _n02, _n03, _n04};  \nendmodule",
