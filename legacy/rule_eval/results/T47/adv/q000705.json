  "final": "module matrix_mult(input [3:0] a11, input [3:0] a12, input [3:0] a21, input [3:0] a22,  \n                   input [3:0] b11, input [3:0] b12, input [3:0] b21, input [3:0] b22,  \n                   output [7:0] c11, output [7:0] c12, output [7:0] c21, output [7:0] c22);  \n\n      wire _n01 = a11 * b11[0] ^ a12 * b21[0];\n  wire _c01 = a11 * b11[0] & a12 * b21[0];\n  wire _n02 = a11 * b11[1] ^ a12 * b21[1] ^ _c01;\n  wire _c02 = (a11 * b11[1] & a12 * b21[1]) | (a11 * b11[1] & _c01) | (a12 * b21[1] & _c01);\n  wire _n03 = a11 * b11[2] ^ a12 * b21[2] ^ _c02;\n  wire _c03 = (a11 * b11[2] & a12 * b21[2]) | (a11 * b11[2] & _c02) | (a12 * b21[2] & _c02);\n  wire _n04 = a11 * b11[3] ^ a12 * b21[3] ^ _c03;\n  wire _c04 = (a11 * b11[3] & a12 * b21[3]) | (a11 * b11[3] & _c03) | (a12 * b21[3] & _c03);\n  assign c11 = {_n01, _n02, _n03, _n04};  \n    assign c12 = a11 * b12 + a12 * b22;  \n    assign c21 = a21 * b11 + a22 * b21;  \n    assign c22 = a21 * b12 + a22 * b22;  \n\nendmodule",
