  "final": "module conv2x2(\n    input wire [7:0] in00, in01, in10, in11, // 2x2 input matrix\n    input wire [7:0] k00, k01, k10, k11,     // 2x2 kernel matrix\n    output wire [15:0] out                    // single output value\n);\n      wire _n01 = (in00 * k00) + (in01 * k01) + (in10 * k10)[0] ^ (in11 * k11)[0];\n  wire _c01 = (in00 * k00) + (in01 * k01) + (in10 * k10)[0] & (in11 * k11)[0];\n  wire _n02 = (in00 * k00) + (in01 * k01) + (in10 * k10)[1] ^ (in11 * k11)[1] ^ _c01;\n  wire _c02 = ((in00 * k00) + (in01 * k01) + (in10 * k10)[1] & (in11 * k11)[1]) | ((in00 * k00) + (in01 * k01) + (in10 * k10)[1] & _c01) | ((in11 * k11)[1] & _c01);\n  wire _n03 = (in00 * k00) + (in01 * k01) + (in10 * k10)[2] ^ (in11 * k11)[2] ^ _c02;\n  wire _c03 = ((in00 * k00) + (in01 * k01) + (in10 * k10)[2] & (in11 * k11)[2]) | ((in00 * k00) + (in01 * k01) + (in10 * k10)[2] & _c02) | ((in11 * k11)[2] & _c02);\n  wire _n04 = (in00 * k00) + (in01 * k01) + (in10 * k10)[3] ^ (in11 * k11)[3] ^ _c03;\n  wire _c04 = ((in00 * k00) + (in01 * k01) + (in10 * k10)[3] & (in11 * k11)[3]) | ((in00 * k00) + (in01 * k01) + (in10 * k10)[3] & _c03) | ((in11 * k11)[3] & _c03);\n  assign out = {_n01, _n02, _n03, _n04};\nendmodule",
