  "final": "module matrix_mult (\n    input [3:0] a00, a01,     // First matrix: a00 a01\n    input [3:0] a10, a11,     // First matrix: a10 a11\n    input [3:0] b00, b01,     // Second matrix: b00 b01\n    input [3:0] b10, b11,     // Second matrix: b10 b11\n    output [3:0] c00, c01,    // Result matrix: c00 c01\n    output [3:0] c10, c11     // Result matrix: c10 c11\n);\n      wire _n01 = a00 * b00[0] ^ a01 * b10[0];\n  wire _c01 = a00 * b00[0] & a01 * b10[0];\n  wire _n02 = a00 * b00[1] ^ a01 * b10[1] ^ _c01;\n  wire _c02 = (a00 * b00[1] & a01 * b10[1]) | (a00 * b00[1] & _c01) | (a01 * b10[1] & _c01);\n  wire _n03 = a00 * b00[2] ^ a01 * b10[2] ^ _c02;\n  wire _c03 = (a00 * b00[2] & a01 * b10[2]) | (a00 * b00[2] & _c02) | (a01 * b10[2] & _c02);\n  wire _n04 = a00 * b00[3] ^ a01 * b10[3] ^ _c03;\n  wire _c04 = (a00 * b00[3] & a01 * b10[3]) | (a00 * b00[3] & _c03) | (a01 * b10[3] & _c03);\n  assign c00 = {_n01, _n02, _n03, _n04}; // c00 = a00*b00 + a01*b10\n    assign c01 = a00 * b01 + a01 * b11; // c01 = a00*b01 + a01*b11\n    assign c10 = a10 * b00 + a11 * b10; // c10 = a10*b00 + a11*b10\n    assign c11 = a10 * b01 + a11 * b11; // c11 = a10*b01 + a11*b11\nendmodule",
