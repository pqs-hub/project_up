  "final": "module RefModule(  \n    input wire [7:0] x0,  \n    input wire [7:0] x1,  \n    input wire [7:0] x2,  \n    output wire [15:0] y  \n);  \n      wire _n01 = (x0 * 1) + (x1 * 2)[0] ^ (x2 * 1)[0];\n  wire _c01 = (x0 * 1) + (x1 * 2)[0] & (x2 * 1)[0];\n  wire _n02 = (x0 * 1) + (x1 * 2)[1] ^ (x2 * 1)[1] ^ _c01;\n  wire _c02 = ((x0 * 1) + (x1 * 2)[1] & (x2 * 1)[1]) | ((x0 * 1) + (x1 * 2)[1] & _c01) | ((x2 * 1)[1] & _c01);\n  wire _n03 = (x0 * 1) + (x1 * 2)[2] ^ (x2 * 1)[2] ^ _c02;\n  wire _c03 = ((x0 * 1) + (x1 * 2)[2] & (x2 * 1)[2]) | ((x0 * 1) + (x1 * 2)[2] & _c02) | ((x2 * 1)[2] & _c02);\n  wire _n04 = (x0 * 1) + (x1 * 2)[3] ^ (x2 * 1)[3] ^ _c03;\n  wire _c04 = ((x0 * 1) + (x1 * 2)[3] & (x2 * 1)[3]) | ((x0 * 1) + (x1 * 2)[3] & _c03) | ((x2 * 1)[3] & _c03);\n  assign y = {_n01, _n02, _n03, _n04};  \nendmodule"
