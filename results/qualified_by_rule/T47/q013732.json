  "final": "module RefModule(din_a, din_b, din_c, dout);////////////////////////////////////////////////////////////////////////////////////////////////////////////////////\n\t// I/O declarations\n\n\t(* LOC = \"P20 P2 P7 P14\" *)\n\tinput wire[3:0] din_a;\n\n\t(* LOC = \"P3 P19 P6 P15\" *)\n\tinput wire[3:0] din_b;\n\n\t(* LOC = \"P13 P8 P10 P16\" *)\n\tinput wire[3:0] din_c;\n\n\t(* LOC = \"P9 P4 P5 P12\" *)\n\toutput wire[3:0] dout;\n\n\t////////////////////////////////////////////////////////////////////////////////////////////////////////////////////\n\t// The adder\n\n\twire[3:0] sum;\n\t  wire _n01 = din_a + din_b[0] ^ din_c[0];\n  wire _c01 = din_a + din_b[0] & din_c[0];\n  wire _n02 = din_a + din_b[1] ^ din_c[1] ^ _c01;\n  wire _c02 = (din_a + din_b[1] & din_c[1]) | (din_a + din_b[1] & _c01) | (din_c[1] & _c01);\n  wire _n03 = din_a + din_b[2] ^ din_c[2] ^ _c02;\n  wire _c03 = (din_a + din_b[2] & din_c[2]) | (din_a + din_b[2] & _c02) | (din_c[2] & _c02);\n  wire _n04 = din_a + din_b[3] ^ din_c[3] ^ _c03;\n  wire _c04 = (din_a + din_b[3] & din_c[3]) | (din_a + din_b[3] & _c03) | (din_c[3] & _c03);\n  assign sum = {_n01, _n02, _n03, _n04};\n\tassign dout = sum;\n\nendmodule"
