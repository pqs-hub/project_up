  "final": "module RefModule (\n    input [3:0] A,\n    input [3:0] B,\n    input SUB,\n    output [3:0] SUM\n);\n\n    wire [3:0] B_comp;\n      wire _n01 = ~B[0] ^ 1[0];\n  wire _c01 = ~B[0] & 1[0];\n  wire _n02 = ~B[1] ^ 1[1] ^ _c01;\n  wire _c02 = (~B[1] & 1[1]) | (~B[1] & _c01) | (1[1] & _c01);\n  wire _n03 = ~B[2] ^ 1[2] ^ _c02;\n  wire _c03 = (~B[2] & 1[2]) | (~B[2] & _c02) | (1[2] & _c02);\n  wire _n04 = ~B[3] ^ 1[3] ^ _c03;\n  wire _c04 = (~B[3] & 1[3]) | (~B[3] & _c03) | (1[3] & _c03);\n  assign B_comp = {_n01, _n02, _n03, _n04};\n\n    assign SUM = (SUB) ? A + B_comp : A + B;\n\nendmodule"
