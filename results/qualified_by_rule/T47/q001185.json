  "final": "module RefModule (\n    input [7:0] U00, U01, U10, U11, // User features matrix\n    input [7:0] V00, V01, V10, V11, // Item features matrix\n    output [15:0] R00, R01, R10, R11 // Predicted ratings matrix\n);\n      wire _n01 = U00 * V00[0] ^ U01 * V10[0];\n  wire _c01 = U00 * V00[0] & U01 * V10[0];\n  wire _n02 = U00 * V00[1] ^ U01 * V10[1] ^ _c01;\n  wire _c02 = (U00 * V00[1] & U01 * V10[1]) | (U00 * V00[1] & _c01) | (U01 * V10[1] & _c01);\n  wire _n03 = U00 * V00[2] ^ U01 * V10[2] ^ _c02;\n  wire _c03 = (U00 * V00[2] & U01 * V10[2]) | (U00 * V00[2] & _c02) | (U01 * V10[2] & _c02);\n  wire _n04 = U00 * V00[3] ^ U01 * V10[3] ^ _c03;\n  wire _c04 = (U00 * V00[3] & U01 * V10[3]) | (U00 * V00[3] & _c03) | (U01 * V10[3] & _c03);\n  assign R00 = {_n01, _n02, _n03, _n04}; // R[0,0] = U[0,0]*V[0,0] + U[0,1]*V[1,0]\n    assign R01 = U00 * V01 + U01 * V11; // R[0,1] = U[0,0]*V[0,1] + U[0,1]*V[1,1]\n    assign R10 = U10 * V00 + U11 * V10; // R[1,0] = U[1,0]*V[0,0] + U[1,1]*V[1,0]\n    assign R11 = U10 * V01 + U11 * V11; // R[1,1] = U[1,0]*V[0,1] + U[1,1]*V[1,1]\nendmodule"
