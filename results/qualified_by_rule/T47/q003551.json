  "final": "module RefModule (\n    input wire [15:0] x0, // Input tap 0\n    input wire [15:0] x1, // Input tap 1\n    input wire [15:0] x2, // Input tap 2\n    input wire [15:0] x3, // Input tap 3\n    output wire [31:0] y   // Output\n);\n    // Coefficients\n    reg [15:0] h0 = 16'h0001; // Coefficient for x0\n    reg [15:0] h1 = 16'h0002; // Coefficient for x1\n    reg [15:0] h2 = 16'h0003; // Coefficient for x2\n    reg [15:0] h3 = 16'h0004; // Coefficient for x3\n\n    // Calculate output\n      wire _n01 = (h0 * x0) + (h1 * x1) + (h2 * x2)[0] ^ (h3 * x3)[0];\n  wire _c01 = (h0 * x0) + (h1 * x1) + (h2 * x2)[0] & (h3 * x3)[0];\n  wire _n02 = (h0 * x0) + (h1 * x1) + (h2 * x2)[1] ^ (h3 * x3)[1] ^ _c01;\n  wire _c02 = ((h0 * x0) + (h1 * x1) + (h2 * x2)[1] & (h3 * x3)[1]) | ((h0 * x0) + (h1 * x1) + (h2 * x2)[1] & _c01) | ((h3 * x3)[1] & _c01);\n  wire _n03 = (h0 * x0) + (h1 * x1) + (h2 * x2)[2] ^ (h3 * x3)[2] ^ _c02;\n  wire _c03 = ((h0 * x0) + (h1 * x1) + (h2 * x2)[2] & (h3 * x3)[2]) | ((h0 * x0) + (h1 * x1) + (h2 * x2)[2] & _c02) | ((h3 * x3)[2] & _c02);\n  wire _n04 = (h0 * x0) + (h1 * x1) + (h2 * x2)[3] ^ (h3 * x3)[3] ^ _c03;\n  wire _c04 = ((h0 * x0) + (h1 * x1) + (h2 * x2)[3] & (h3 * x3)[3]) | ((h0 * x0) + (h1 * x1) + (h2 * x2)[3] & _c03) | ((h3 * x3)[3] & _c03);\n  assign y = {_n01, _n02, _n03, _n04};\nendmodule"
