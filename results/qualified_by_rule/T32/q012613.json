  "final": "module RefModule(\n    input [4-1:1-1] bin,\n    input en,\n    output reg [15:0] dec\n    );\n\n    always @(*) begin\n        if (en) begin\n            case (bin)\n                4'b0000: dec = 16'b0000000000000001; // 0000 -> 0000000000000001\n                4'b0001: dec = 16'b0000000000000010; // 0001 -> 0000000000000010\n                4'b0010: dec = 16'b0000000000000100; // 0010 -> 0000000000000100\n                4'b0011: dec = 16'b0000000000001000; // 0011 -> 0000000000001000\n                4'b0100: dec = 16'b0000000000010000; // 0100 -> 0000000000010000\n                4'b0101: dec = 16'b0000000000100000; // 0101 -> 0000000000100000\n                4'b0110: dec = 16'b0000000001000000; // 0110 -> 0000000001000000\n                4'b0111: dec = 16'b0000000010000000; // 0111 -> 0000000010000000\n                4'b1000: dec = 16'b0000000100000000; // 1000 -> 0000000100000000\n                4'b1001: dec = 16'b0000001000000000; // 1001 -> 0000001000000000\n                4'b1010: dec = 16'b0000010000000000; // 1010 -> 0000010000000000\n                4'b1011: dec = 16'b0000100000000000; // 1011 -> 0000100000000000\n                4'b1100: dec = 16'b0001000000000000; // 1100 -> 0001000000000000\n                4'b1101: dec = 16'b0010000000000000; // 1101 -> 0010000000000000\n                4'b1110: dec = 16'b0100000000000000; // 1110 -> 0100000000000000\n                4'b1111: dec = 16'b1000000000000000; // 1111 -> 1000000000000000\n                default: dec = 16'b0000000000000000; // Default to 0\n            endcase\n        end else\n            dec = 16'b0000000000000000; // All zeros when disabled\n    end\nendmodule"
